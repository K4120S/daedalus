{
    "_instructions": "Copy this file to master_mcp_config.json and fill in real values. master_mcp_config.json is gitignored — never commit real keys.",
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/Users/YOUR_USERNAME/Desktop"
            ]
        },
        "brave-search": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-brave-search"
            ],
            "env": {
                "BRAVE_API_KEY": "YOUR_BRAVE_API_KEY_HERE"
            }
        }
    }
}
